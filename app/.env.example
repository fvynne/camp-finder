# Copy to ".env". Expo exposes vars prefixed with EXPO_PUBLIC_ to the app.
# These two are SAFE to ship in the client (the anon key is public by design;
# Row Level Security protects your data).
#
# Supabase dashboard -> Project Settings -> API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
