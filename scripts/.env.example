# Copy this file to ".env" and fill in your keys. NEVER commit the real .env.

# Google Cloud key with "Places API (New)" enabled (see project README, section 4).
GOOGLE_MAPS_API_KEY=

# Supabase project credentials.
# URL:  Supabase dashboard -> Project Settings -> API -> Project URL
# KEY:  Project Settings -> API -> service_role secret  (server-side only — never ship in the app)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional: only needed for the AI enrichment script (enrich-camps.js).
# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=
